rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // All reads/writes for posts and leads go through the Admin SDK on the
    // server (Route Handlers / Server Actions). Deny direct client access
    // entirely so there's no client-side security surface to reason about.
    match /posts/{postId} {
      allow read, write: if false;
    }

    match /leads/{leadId} {
      allow read, write: if false;
    }
  }
}
