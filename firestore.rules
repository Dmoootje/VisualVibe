rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Everything here goes through the Admin SDK on the server (Route
    // Handlers / Server Actions), which bypasses these rules entirely. They
    // exist as defense-in-depth so an accidental client-side Firestore call
    // is denied rather than silently allowed.
    match /posts/{postId} {
      allow read, write: if false;
    }

    match /leads/{leadId} {
      allow read, write: if false;
    }

    match /lead_notes/{noteId} {
      allow read, write: if false;
    }

    match /lead_events/{eventId} {
      allow read, write: if false;
    }

    match /newsletter_subscribers/{subscriberId} {
      allow read, write: if false;
    }

    match /profiles/{profileId} {
      allow read, write: if false;
    }

    match /site_settings/{settingsId} {
      allow read, write: if false;
    }

    match /email_settings/{settingsId} {
      allow read, write: if false;
    }

    match /ai_settings/{settingsId} {
      allow read, write: if false;
    }

    match /mail_history/{mailId} {
      allow read, write: if false;
    }

    match /mail_dispatches/{dispatchId} {
      allow read, write: if false;
    }

    match /counters/{counterId} {
      allow read, write: if false;
    }

    match /lead_rate_limits/{rateLimitId} {
      allow read, write: if false;
    }

    match /analysis_leads/{analysisLeadId} {
      allow read, write: if false;
    }

    match /analysis_reports/{analysisReportId} {
      allow read, write: if false;
    }

    match /analysis_settings/{analysisSettingsId} {
      allow read, write: if false;
    }

    match /analysis_quota/{analysisQuotaId} {
      allow read, write: if false;
    }

    match /analysis_reservations/{analysisReservationId} {
      allow read, write: if false;
    }
  }
}
